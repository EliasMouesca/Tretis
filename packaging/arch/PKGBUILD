pkgname=tretis
pkgver=0.1.0
pkgrel=1
pkgdesc='Small SDL3 Tetris implementation'
arch=('x86_64')
url='https://example.invalid/tretis'
license=('custom')
depends=('sdl3' 'sdl3_ttf')
makedepends=('gcc' 'make' 'pkgconf')
source=()
sha256sums=()

build() {
    cd "$startdir/../.."
    make
}

package() {
    cd "$startdir/../.."
    make DESTDIR="$pkgdir" PREFIX=/usr install
}
